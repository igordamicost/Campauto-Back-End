NODE_ENV=development
PORT=3000
DB_HOST=mysql
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=admin
DB_NAME=campauto

# URL do frontend (OBRIGATÓRIO em produção - links de e-mail usarão este domínio)
# Em produção: FRONT_URL=https://seudominio.com.br
FRONT_URL=http://localhost:3000

# Nome da empresa (usado em e-mails quando usuário não tem empresa vinculada)
COMPANY_NAME=Campauto

# Logo inline em e-mails (CID) - prioridade: logo_url da empresa > COMPANY_LOGO_URL > COMPANY_LOGO_PATH
# COMPANY_LOGO_URL=https://seudominio.com/logo.png
# COMPANY_LOGO_PATH=./public/logo.png

MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USER=seuemail@dominio.com
MAIL_PASS=suasenha
MAIL_FROM=seuemail@dominio.com

# Auth - Access token + Refresh token rotativo
JWT_SECRET=seu_segredo_jwt_minimo_32_caracteres
ACCESS_TOKEN_TTL_MIN=10
REFRESH_TOKEN_TTL_DAYS=7
IDLE_TIMEOUT_MIN=30
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=seudominio.com.br
# CORS_ORIGINS=https://seudominio.com.br,https://app.seudominio.com.br
