# ===========================================
# Campauto Backend - Variáveis de Ambiente
# ===========================================
# Copie para .env e preencha os valores

NODE_ENV=production
PORT=3000

# Banco de dados
DB_HOST=172.18.0.1
DB_PORT=3306
DB_USER=admin
DB_PASS=admin
DB_NAME=campauto

# E-mail (SMTP Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=comunicacao@seudominio.com.br
SMTP_PASS=suasenha

# Aplicação
FRONT_URL=https://seudominio.com.br
COMPANY_NAME=Campauto
COMPANY_LOGO_URL=https://seudominio.com.br

# Auth (obrigatório)
JWT_SECRET=seu_segredo_jwt_minimo_32_caracteres

# Auth - Access token + Refresh token rotativo
ACCESS_TOKEN_TTL_MIN=10
REFRESH_TOKEN_TTL_DAYS=7
IDLE_TIMEOUT_MIN=30
COOKIE_SECURE=true
# Para cross-origin (frontend e API em domínios diferentes): COOKIE_SAMESITE=none
# Para mesmo domínio (app.exemplo.com + api.exemplo.com): COOKIE_SAMESITE=lax
COOKIE_SAMESITE=lax
# Para domínios com acento (ex: jrcarpeças.com.br), use punycode:
# COOKIE_DOMAIN=xn--jrcarpeas-w3a.com.br
# Ou remova COOKIE_DOMAIN para cookie no host atual
# CORS_ORIGINS: origens permitidas (CSRF + CORS). Aceita IDN e punycode.
# Ex: https://jrcarpecas.com.br ou https://xn--jrcarpeas-w3a.com.br
CORS_ORIGINS=https://seudominio.com.br
